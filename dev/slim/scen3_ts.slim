// =====================================================================
// Scenario 3 (tree-sequence): WF 2D stepping-stone with ASYMMETRIC
// (downstream-biased) migration along an elevation gradient and UNIFORM deme
// sizes (so the signal is directional movement, not drift). Immigration into
// deme i from neighbour k is m0 * exp(BETA_DIR * (elev_k - elev_i)): higher
// from uphill neighbours, i.e. net downhill gene flow. BETA_DIR = 0 is
// symmetric migration (isolation by resistance).
//
// Validates Tier 3: fit terradish_directed() with an elevation directional
// covariate; expect gamma recovered (correct sign) and preferred over the
// symmetric model. Output: tree sequence + per-deme meta (incl. elevation) for
// the recapitation pipeline.
//
// CLI: slim -seed 1 -d "OUTPRE='dev/slim/scen3ts'" dev/slim/scen3_ts.slim
// =====================================================================
initialize() {
    initializeTreeSeq();
    if (!exists("DIM"))      defineConstant("DIM", 5);
    if (!exists("N0"))       defineConstant("N0", 200);      // uniform deme size
    if (!exists("MIG"))      defineConstant("MIG", 0.02);    // base migration
    if (!exists("BETA_DIR")) defineConstant("BETA_DIR", 0.8);// downhill bias strength
    if (!exists("RHO"))      defineConstant("RHO", 1e-8);
    if (!exists("L"))        defineConstant("L", 1000000);
    if (!exists("BURNIN"))   defineConstant("BURNIN", 4000);
    if (!exists("OUTPRE"))   defineConstant("OUTPRE", "scen3ts");

    initializeMutationRate(0);
    initializeMutationType("m1", 0.5, "f", 0.0);
    initializeGenomicElementType("g1", m1, 1.0);
    initializeGenomicElement(g1, 0, asInteger(L) - 1);
    initializeRecombinationRate(RHO);
}

1 early() {
    ndeme = DIM * DIM;
    gx = float(ndeme); gy = float(ndeme);
    for (i in 0:(ndeme - 1)) {
        gx[i] = i % DIM;
        gy[i] = (i - (i % DIM)) / DIM;
    }
    elev = (gx - mean(gx)) / sd(gx);            // standardized elevation gradient
    defineConstant("GX", gx);
    defineConstant("GY", gy);
    defineConstant("ELEV", elev);

    for (i in 0:(ndeme - 1))
        sim.addSubpop(i, N0);

    // asymmetric immigration: into i from neighbour k at MIG*exp(BETA_DIR*(elev_k - elev_i))
    for (i in 0:(ndeme - 1)) {
        cx = i % DIM; cy = (i - (i % DIM)) / DIM;
        srcs = integer(0);
        if (cx > 0)        srcs = c(srcs, i - 1);
        if (cx < DIM - 1)  srcs = c(srcs, i + 1);
        if (cy > 0)        srcs = c(srcs, i - DIM);
        if (cy < DIM - 1)  srcs = c(srcs, i + DIM);
        rates = MIG * exp(BETA_DIR * (elev[srcs] - elev[i]));
        rates = pmin(rates, 0.45 / size(srcs));  // keep total immigration < 1
        sim.subpopulations[i].setMigrationRates(srcs, rates);
    }
    community.rescheduleScriptBlock(s1, BURNIN, BURNIN);
}

s1 2 late() {
    ndeme = DIM * DIM;
    sim.treeSeqOutput(OUTPRE + ".trees");
    dmeta = "deme,gx,gy,elev,size";
    for (i in 0:(ndeme - 1))
        dmeta = c(dmeta, i + "," + GX[i] + "," + GY[i] + "," + ELEV[i] + "," + N0);
    writeFile(OUTPRE + "_demes.csv", dmeta);
    catn("scenario 3 (tree-seq) done: " + ndeme + " demes, asymmetric migration BETA_DIR=" + BETA_DIR);
    sim.simulationFinished();
}
