# Editor-level line-ending/whitespace policy, complementing .gitattributes.
# Keeps newly created files LF so CRLF doesn't creep back in (RStudio and
# VS Code both honour this).
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Windows batch files, if ever added, keep CRLF
[*.{bat,cmd}]
end_of_line = crlf

# Don't enforce whitespace trimming inside Markdown (trailing spaces = hard break)
[*.md]
trim_trailing_whitespace = false
